name: tiktok_flutter
description: "A TikTok clone application"
publish_to: 'none'
version: 1.0.0+1

environment:
  sdk: ^3.5.0

dependencies:
  flutter:
    sdk: flutter

  # UI & Icons
  cupertino_icons: ^1.0.6
  
  # Video Player
  video_player: ^2.8.1
  
  # State Management
  provider: ^6.1.1
  
  # Networking & Images
  cached_network_image: ^3.3.0
  
  # Utilities
  visibility_detector: ^0.4.0+2

  # Supabase
  supabase_flutter: ^2.8.1

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^3.0.0

flutter:
  uses-material-design: true
  
  fonts:
    - family: TikTokIcons
      fonts:
        - asset: assets/fonts/TikTokIcons.ttf
  
  assets:
    - assets/images/
    - assets/fonts/